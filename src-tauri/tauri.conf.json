{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "WisFlow",
  "version": "0.0.0",
  "identifier": "com.wisflow.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev:vite",
    "beforeBuildCommand": "npm run build:vite"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "mic-indicator",
        "title": "WisFlow",
        "width": 80,
        "height": 80,
        "resizable": false,
        "alwaysOnTop": true,
        "decorations": false,
        "transparent": true,
        "visible": false,
        "skipTaskbar": true,
        "focus": false
      },
      {
        "label": "main",
        "title": "WisFlow 设置",
        "width": 860,
        "height": 680,
        "resizable": false,
        "visible": false,
        "center": true,
        "skipTaskbar": false
      }
    ],
    "trayIcon": {
      "iconPath": "icons/icon.png",
      "iconAsTemplate": true
    },
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
